{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonomous-coding-agent.local/schemas/run-contract.schema.json",
  "title": "Run Contract Schema",
  "description": "Schema for the per-run task contract described in canonical-architecture.md Section 8.2 \"Run Contract\" and IMPLEMENTATION-PLAN.md Phase 0 benchmark fixtures. Queue-mode metadata stays optional because not every run is queue-claimed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "repo_path",
    "objective",
    "scope",
    "acceptance",
    "constraints"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Stable identifier for a specific run."
    },
    "repo_path": {
      "type": "string",
      "description": "Absolute path to the target repo."
    },
    "objective": {
      "type": "string",
      "description": "The coding objective for this run."
    },
    "scope": {
      "type": "object",
      "description": "Bounded path scope enforced by the supervisor.",
      "additionalProperties": false,
      "required": [
        "allowed_paths",
        "forbidden_paths"
      ],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "forbidden_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "functional",
        "quality_gates",
        "ui_checks"
      ],
      "properties": {
        "functional": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "quality_gates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ui_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "single_writer",
        "max_repair_loops",
        "max_iterations",
        "max_cost_dollars",
        "hard_timeout_seconds"
      ],
      "properties": {
        "single_writer": {
          "type": "boolean"
        },
        "auto_push": {
          "type": "boolean"
        },
        "auto_merge": {
          "type": "boolean"
        },
        "max_repair_loops": {
          "type": "integer",
          "minimum": 0
        },
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "max_cost_dollars": {
          "type": "number",
          "minimum": 0
        },
        "hard_timeout_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "claim_id": {
      "type": "string"
    },
    "run_trace_id": {
      "type": "string"
    },
    "queue_entry_reason": {
      "type": "string"
    },
    "queue_contract_version": {
      "type": "string"
    },
    "prompt_template_version": {
      "type": "string"
    },
    "issue_snapshot_hash": {
      "type": "string"
    },
    "follow_up_policy": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High"
      ]
    },
    "approval_required": {
      "type": "boolean"
    },
    "retry_budget": {
      "type": "integer",
      "minimum": 0
    },
    "staleness_deadline": {
      "type": "string"
    }
  },
  "examples": [
    {
      "run_id": "benchmark-001",
      "repo_path": "/path/to/repo",
      "objective": "Add a GET /api/users/:id endpoint that returns user data by ID",
      "scope": {
        "allowed_paths": [
          "src/api/",
          "src/models/",
          "tests/"
        ],
        "forbidden_paths": [
          ".env",
          "infra/",
          "deploy/"
        ]
      },
      "acceptance": {
        "functional": [
          "GET /api/users/1 returns user object with id, name, email",
          "GET /api/users/999 returns 404"
        ],
        "quality_gates": [
          "lint passes",
          "typecheck passes",
          "tests pass"
        ]
      },
      "constraints": {
        "single_writer": true,
        "auto_push": false,
        "auto_merge": false,
        "max_repair_loops": 4,
        "max_iterations": 50,
        "max_cost_dollars": 10.0,
        "hard_timeout_seconds": 3600
      }
    },
    {
      "run_id": "queue-claim-001",
      "repo_path": "/path/to/repo",
      "objective": "Fix the login form validation bug",
      "scope": {
        "allowed_paths": [
          "apps/web/",
          "tests/"
        ],
        "forbidden_paths": [
          ".env",
          "infra/"
        ]
      },
      "acceptance": {
        "functional": [
          "Login validation message renders correctly"
        ],
        "quality_gates": [
          "tests pass"
        ],
        "ui_checks": [
          "No console errors on /login"
        ]
      },
      "constraints": {
        "single_writer": true,
        "max_repair_loops": 3,
        "max_iterations": 40,
        "max_cost_dollars": 8.0,
        "hard_timeout_seconds": 1800
      },
      "claim_id": "claim-123",
      "run_trace_id": "trace-123",
      "queue_entry_reason": "Ready for Build queue claim",
      "queue_contract_version": "2026-04-16",
      "prompt_template_version": "2026-04-16",
      "issue_snapshot_hash": "abc123",
      "follow_up_policy": "adjacent-blocker-only",
      "risk_level": "Low",
      "approval_required": false,
      "retry_budget": 3,
      "staleness_deadline": "2026-04-17T00:00:00Z"
    }
  ]
}
